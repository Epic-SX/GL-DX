# Database
DATABASE_URL=postgresql://gl_user:gl_password@db:5432/gl_dx
DB_PASSWORD=gl_password

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# File Storage (local or s3)
STORAGE_TYPE=local
UPLOAD_DIR=uploads

# AWS S3 (optional, set STORAGE_TYPE=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=ap-northeast-1

# EC Channels (fill in your API keys)
YAHOO_AUCTION_CLIENT_ID=
YAHOO_AUCTION_CLIENT_SECRET=
MERCARI_API_KEY=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_SELLER_ID=
RAKUTEN_SERVICE_SECRET=
RAKUTEN_LICENSE_KEY=

# Sagawa e-Delivery
SAGAWA_CLIENT_CODE=
SAGAWA_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
